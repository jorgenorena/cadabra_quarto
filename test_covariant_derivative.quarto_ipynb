      "source": [
        "---\n",
        "title: \"Test: Covariant Derivative\"\n",
        "cadabra-deps:\n",
        "    - \"tests/test_covariant_derivative.cdb\"\n",
        "    - \"tests/test_adm_kinematics.cdb\"\n",
        "---\n",
        "\n",
        "\n",
        "If the pipeline works, this should output the covariant derivative of the tensor $T^b{}_c$ in terms of the partial derivative and the Christoffel symbols.\n"
      ],
      "id": "5c70c68e"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| echo: false\n",
        "#| output: asis\n",
        "\n",
        "from pathlib import Path\n",
        "\n",
        "tex = Path(\"results/test_covariant_derivative.tex\").read_text(encoding=\"utf-8\").strip()\n",
        "\n",
        "print(\"::: {.scroll-math}\")\n",
        "print(\"$$\")\n",
        "print(tex)\n",
        "print(\"$$\")\n",
        "print(\":::\")"
      ],
      "id": "4349c05b",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "#| echo: false\n",
        "#| output: asis\n",
        "\n",
        "from pathlib import Path\n",
        "\n",
        "tex = Path(\"results/test_adm_kinematics.tex\").read_text(encoding=\"utf-8\").strip()\n",
        "tex = tex.replace(r\"\\GammaThree\", r\"{}^{(3)}\\Gamma\")\n",
        "\n",
        "print(\"::: {.scroll-math}\")\n",
        "print(\"$$\")\n",
        "print(tex)\n",
        "print(\"$$\")\n",
        "print(\":::\")"
      ],
      "id": "21c0aec5",
      "execution_count": null,
      "outputs": []
    }
