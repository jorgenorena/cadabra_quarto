from algebra.defs import *
from algebra.expand_cd import *
from algebra.adm import *

ex := D_{I}{A^{J}_{K}};

result = expand_cd(ex, cd=r'D', pd=r'\partial', conn=r'\GammaThree', to_index_set='space_fixed');

canonicalise(ex);

latex_code = result._latex_()
with open("results/test_adm_kinematics.tex", "w") as f:
    f.write(latex_code + "\n")